#!/bin/bash

COVER_CACHE="/tmp/.spotify_cover.jpg"
DEFAULT_COVER="images/music.png"

resolve_player() {
	playerctl --list-all 2>/dev/null | awk '
		/spotify/i { print; found=1; exit }
		{ if (first == "") first = $0 }
		END { if (!found && first != "") print first }
	'
}

player_ok() {
	PLAYER="$(resolve_player)"
	[[ -n "$PLAYER" ]] || return 1
	playerctl --player="$PLAYER" status >/dev/null 2>&1
}

get_status() {
	if ! player_ok; then
		echo "喇"
		return
	fi

	status="$(playerctl --player="$PLAYER" status 2>/dev/null)"
	if [[ "$status" == "Playing" ]]; then
		echo ""
	else
		echo "喇"
	fi
}

get_song() {
	if ! player_ok; then
		echo "Offline"
		return
	fi

	song="$(playerctl --player="$PLAYER" metadata title 2>/dev/null)"
	if [[ -n "$song" ]]; then
		echo "$song"
	else
		echo "Spotify"
	fi
}

get_artist() {
	if ! player_ok; then
		echo "Offline"
		return
	fi

	artist="$(playerctl --player="$PLAYER" metadata artist 2>/dev/null | head -n 1)"
	if [[ -n "$artist" ]]; then
		echo "$artist"
	else
		echo "No track"
	fi
}

get_position_seconds() {
	playerctl --player="$PLAYER" position 2>/dev/null || echo "0"
}

get_length_seconds() {
	length_us="$(playerctl --player="$PLAYER" metadata mpris:length 2>/dev/null)"
	if [[ -z "$length_us" ]]; then
		echo "0"
	else
		awk -v us="$length_us" 'BEGIN { printf "%.0f\n", us / 1000000 }'
	fi
}

format_time() {
	seconds="$1"
	awk -v s="$seconds" 'BEGIN {
		if (s < 0 || s == "") s = 0;
		m = int(s / 60);
		sec = int(s % 60);
		printf "%d:%02d\n", m, sec;
	}'
}

get_time() {
	if ! player_ok; then
		echo "0"
		return
	fi

	position="$(get_position_seconds)"
	length="$(get_length_seconds)"
	if [[ "$length" -le 0 ]]; then
		echo "0"
	else
		awk -v p="$position" -v l="$length" 'BEGIN {
			if (l <= 0) { print 0; exit }
			val = int((p / l) * 100);
			if (val < 0) val = 0;
			if (val > 100) val = 100;
			print val;
		}'
	fi
}

get_ctime() {
	if ! player_ok; then
		echo "0:00"
		return
	fi

	format_time "$(get_position_seconds)"
}

get_ttime() {
	if ! player_ok; then
		echo "0:00"
		return
	fi

	format_time "$(get_length_seconds)"
}

get_cover() {
	if ! player_ok; then
		echo "$DEFAULT_COVER"
		return
	fi

	art_url="$(playerctl --player="$PLAYER" metadata mpris:artUrl 2>/dev/null)"
	if [[ -z "$art_url" ]]; then
		echo "$DEFAULT_COVER"
		return
	fi

	if [[ "$art_url" == file://* ]]; then
		echo "${art_url#file://}"
		return
	fi

	if [[ "$art_url" =~ ^https?:// ]] && command -v curl >/dev/null 2>&1; then
		if curl -Lfs "$art_url" -o "$COVER_CACHE" >/dev/null 2>&1; then
			echo "$COVER_CACHE"
			return
		fi
	fi

	echo "$DEFAULT_COVER"
}

toggle() {
	player_ok && playerctl --player="$PLAYER" play-pause >/dev/null 2>&1
}

next_track() {
	player_ok && playerctl --player="$PLAYER" next >/dev/null 2>&1
}

prev_track() {
	player_ok && playerctl --player="$PLAYER" previous >/dev/null 2>&1
}

case "$1" in
	--song) get_song ;;
	--artist) get_artist ;;
	--status) get_status ;;
	--time) get_time ;;
	--ctime) get_ctime ;;
	--ttime) get_ttime ;;
	--cover) get_cover ;;
	--toggle) toggle ;;
	--next) next_track ;;
	--prev) prev_track ;;
	*) exit 1 ;;
esac
