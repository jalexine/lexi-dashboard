#!/usr/bin/env python3

import datetime as dt
import json
import random
import re
import sys
import urllib.parse
import urllib.request
from pathlib import Path


SEARCH_URL = "https://collectionapi.metmuseum.org/public/collection/v1/search"
OBJECT_URL = "https://collectionapi.metmuseum.org/public/collection/v1/objects"
CACHE_DIR = Path.home() / ".cache" / "eww" / "artic_art"
STATE_FILE = CACHE_DIR / "art.json"
DEFAULT_IMAGE = str(Path.home() / ".config" / "eww" / "dashboard" / "images" / "music.png")
POOL_SIZE = 10

DEFAULT_ART = {
    "image": DEFAULT_IMAGE,
    "title": "Artwork of the day",
    "artist": "The Met",
    "year": "",
    "page": "https://www.metmuseum.org/art/collection",
}

DEFAULT_STATE = {
    "date": "",
    "current_index": 0,
    "artworks": [DEFAULT_ART],
}


def request_json(url, params=None):
    params = params or {}
    query = urllib.parse.urlencode(params)
    full_url = f"{url}?{query}" if query else url
    req = urllib.request.Request(full_url, headers={"User-Agent": "eww-met-art/1.0"})
    with urllib.request.urlopen(req, timeout=20) as resp:
        return json.load(resp)


def download_file(url, target):
    req = urllib.request.Request(url, headers={"User-Agent": "eww-met-art/1.0"})
    with urllib.request.urlopen(req, timeout=30) as resp:
        target.write_bytes(resp.read())


def clean_text(value, fallback):
    text = str(value or "").replace("\n", " ")
    text = re.sub(r"\s+", " ", text).strip()
    return text or fallback


def extract_year(value):
    text = clean_text(value, "")
    match = re.search(r"\b(1[0-9]{3}|20[0-9]{2})\b", text)
    return match.group(1) if match else ""


def image_path_for_id(art_id):
    return CACHE_DIR / f"art_{art_id}.jpg"


def load_state():
    if not STATE_FILE.exists():
        return DEFAULT_STATE.copy()
    try:
        data = json.loads(STATE_FILE.read_text())
    except Exception:
        return DEFAULT_STATE.copy()

    if not data.get("artworks"):
        data["artworks"] = [DEFAULT_ART]
    if data.get("current_index") is None:
        data["current_index"] = 0
    data.setdefault("date", "")
    return data


def save_state(state):
    CACHE_DIR.mkdir(parents=True, exist_ok=True)
    STATE_FILE.write_text(json.dumps(state))


def current_artwork(state):
    artworks = state.get("artworks") or [DEFAULT_ART]
    index = max(0, min(state.get("current_index", 0), len(artworks) - 1))
    return {**DEFAULT_ART, **artworks[index]}


def search_object_ids():
    data = request_json(
        SEARCH_URL,
        {
            "q": "painting",
            "hasImages": "true",
        },
    )
    return data.get("objectIDs") or []


def fetch_object(art_id):
    data = request_json(f"{OBJECT_URL}/{art_id}")
    image_url = data.get("primaryImageSmall") or data.get("primaryImage")
    if not image_url:
        return None

    artist = clean_text(data.get("artistDisplayName"), "Unknown artist")
    return {
        "id": art_id,
        "title": clean_text(data.get("title"), DEFAULT_ART["title"]),
        "artist": artist,
        "year": extract_year(data.get("objectDate")),
        "image_url": image_url,
        "page": clean_text(data.get("objectURL"), f"https://www.metmuseum.org/art/collection/search/{art_id}"),
    }


def build_daily_pool():
    try:
        object_ids = search_object_ids()
        if not object_ids:
            raise RuntimeError("no objects")

        seed = dt.date.today().toordinal()
        rng = random.Random(seed * 17 + 3)
        selected_ids = rng.sample(object_ids, min(POOL_SIZE * 3, len(object_ids)))
        artworks = []

        CACHE_DIR.mkdir(parents=True, exist_ok=True)
        for art_id in selected_ids:
            if len(artworks) >= POOL_SIZE:
                break
            try:
                item = fetch_object(art_id)
                if not item:
                    continue
                image_path = image_path_for_id(art_id)
                download_file(item["image_url"], image_path)
                artworks.append(
                    {
                        "image": str(image_path),
                        "title": item["title"],
                        "artist": item["artist"],
                        "year": item["year"],
                        "page": item["page"],
                    }
                )
            except Exception:
                continue

        if not artworks:
            artworks = [DEFAULT_ART]

        state = {
            "date": dt.date.today().isoformat(),
            "current_index": 0,
            "artworks": artworks,
        }
        save_state(state)
        return state
    except Exception:
        state = load_state()
        if state.get("artworks"):
            return state
        save_state(DEFAULT_STATE)
        return DEFAULT_STATE.copy()


def ensure_state():
    state = load_state()
    if state.get("date") == dt.date.today().isoformat() and state.get("artworks"):
        return state
    return build_daily_pool()


def next_artwork():
    state = ensure_state()
    artworks = state.get("artworks") or [DEFAULT_ART]
    if len(artworks) > 1:
        state["current_index"] = (state.get("current_index", 0) + 1) % len(artworks)
        save_state(state)
    return state


def rebuild_pool():
    return build_daily_pool()


def main():
    if "--next" in sys.argv:
        state = next_artwork()
    elif "--refresh" in sys.argv:
        state = rebuild_pool()
    else:
        state = ensure_state()

    art = current_artwork(state)
    if "--image" in sys.argv:
        print(art.get("image", DEFAULT_IMAGE))
    elif "--title" in sys.argv:
        print(art.get("title", DEFAULT_ART["title"]))
    elif "--artist" in sys.argv:
        print(art.get("artist", DEFAULT_ART["artist"]))
    elif "--year" in sys.argv:
        print(art.get("year", ""))
    elif "--page" in sys.argv:
        print(art.get("page", DEFAULT_ART["page"]))
    elif "--refresh" in sys.argv or "--next" in sys.argv:
        print("ok")
    else:
        sys.exit(1)


if __name__ == "__main__":
    main()
