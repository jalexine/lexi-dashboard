#!/bin/bash

FILE="$HOME/.cache/eww_launch.dashboard"
CFG="$HOME/.config/eww/dashboard"
EWW="$(command -v eww)"
OPEN_WINDOWS=(
	profile
	system
	clock
	music
	github
	reddit
	twitter
	youtube
	weather
	hackernews
	logout
	sleep
	reboot
	poweroff
	folders
)

CLOSE_WINDOWS=(
	"${OPEN_WINDOWS[@]}"
)

ensure_daemon() {
	if ! "${EWW}" --config "$CFG" ping >/dev/null 2>&1; then
		"${EWW}" --config "$CFG" daemon
		sleep 1
	fi
}

open_dashboard() {
	"${EWW}" --config "$CFG" open-many "${OPEN_WINDOWS[@]}"
}

close_dashboard() {
	mapfile -t open_windows < <(
		"${EWW}" --config "$CFG" active-windows 2>/dev/null | sed 's/^[^:]*: //'
	)

	to_close=()
	for window in "${CLOSE_WINDOWS[@]}"; do
		for open_window in "${open_windows[@]}"; do
			if [[ "$window" == "$open_window" ]]; then
				to_close+=("$window")
				break
			fi
		done
	done

	if [[ ${#to_close[@]} -gt 0 ]]; then
		"${EWW}" --config "$CFG" close "${to_close[@]}"
	fi
}

ensure_daemon

if [[ ! -f "$FILE" ]]; then
	touch "$FILE"
	open_dashboard
else
	close_dashboard
	rm -f "$FILE"
fi
